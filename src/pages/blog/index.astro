---
import { posts } from "../../data/posts";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="블로그 | takeown.github.io"
  description="개발하면서 남기는 기록과 메모."
>
  <section class="blog-page" aria-labelledby="blog-title">
    <div class="page-heading">
      <p class="eyebrow">블로그</p>
      <h1 id="blog-title">작업하면서 남기는 기록.</h1>
      <p>
        개인 사이트를 손보면서 배운 것들, 결정한 것들, 나중에 다시 볼 만한
        내용을 정리합니다.
      </p>
    </div>

    <div class="post-list">
      {
        posts.map((post) => (
          <article class="post-item">
            <div class="post-meta">
              <span>{post.tag}</span>
              <time datetime={post.dateTime}>{post.date}</time>
            </div>
            <h2>
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h2>
            <p>{post.summary}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
