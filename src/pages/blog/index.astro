---
import { posts } from "../../data/posts";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Blog | takeown.github.io"
  description="Field notes from the rebuild."
>
  <section class="blog-page" aria-labelledby="blog-title">
    <div class="page-heading">
      <p class="eyebrow">Blog</p>
      <h1 id="blog-title">Field notes from the rebuild.</h1>
      <p>
        Posts now live at real static routes, including individual detail pages
        under <code>/blog/[slug]</code>.
      </p>
    </div>

    <div class="post-list">
      {
        posts.map((post) => (
          <article class="post-item">
            <div class="post-meta">
              <span>{post.tag}</span>
              <time datetime={post.dateTime}>{post.date}</time>
            </div>
            <h2>
              <a href={`/blog/${post.slug}/`}>{post.title}</a>
            </h2>
            <p>{post.summary}</p>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
